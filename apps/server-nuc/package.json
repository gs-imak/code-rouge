{
  "name": "@code-rouge/server-nuc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local Node server hosted on the Intel NUC — WebSocket + SQLite + HTTP health",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@code-rouge/shared-types": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "express": "^4.22.1",
    "pino": "^9.14.0",
    "tsx": "^4.21.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^11.3.0"
  }
}
