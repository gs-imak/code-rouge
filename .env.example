# Dev-time tooling secrets. Copy this file to `.env` (already gitignored) and
# fill in the values. These are NOT bundled into the offline player apps — they
# are used only by build/design tooling on the developer machine.

# Figma personal access token (read-only) — used to pull the M2 maquettes via
# the Figma REST API during design integration.
#   Create: Figma (browser) → avatar → Settings → Security → Personal access
#           tokens → Generate new token.
#   Scope:  "File content" = Read-only is enough. Revoke after M2.
FIGMA_TOKEN=
