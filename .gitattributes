# Normalize line endings to LF in the repo. Windows checkouts get CRLF locally
# only when core.autocrlf=true; we want LF in the working tree for shell scripts
# and cross-platform consistency (Linux NUC, macOS dev, Windows dev).
* text=auto eol=lf

# Always LF — required for shell scripts running on the NUC (load-bearing,
# kept explicit because some Windows checkouts override `text=auto eol=lf`
# for known-text extensions).
*.sh           text eol=lf
*.bash         text eol=lf

# Binary files
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.mp3          binary
*.mp4          binary
*.zip          binary
*.gz           binary
*.tar          binary
*.apk          binary
*.aab          binary
*.exe          binary
*.dmg          binary
*.AppImage     binary
*.sqlite       binary
*.jks          binary
*.keystore     binary
